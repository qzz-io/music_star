# Set default behavior to automatic text/binary detection
* text=auto

# Force Kotlin/build files to use LF line endings
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.properties text eol=lf

# Force script files to use LF line endings and be executable
gradlew text eol=lf

# Force Windows batch files to use CRLF
*.bat text eol=crlf

# Direct git to treat these files strictly as binary
*.jar binary
*.png binary
*.webp binary
*.jpg binary
*.jpeg binary
*.keystore binary
