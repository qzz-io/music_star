<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="@drawable/widget_bg"
    android:clickable="true"
    android:focusable="true"
    android:padding="12dp">

    <!-- Artwork on the left -->
    <FrameLayout
        android:id="@+id/artwork_container"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:background="@drawable/widget_artwork_bg"
        android:padding="14dp">

        <ImageView
            android:id="@+id/widget_artwork_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_widget_music"
            android:contentDescription="Music Icon"
            android:scaleType="fitCenter" />
    </FrameLayout>

    <!-- Controls on the far right -->
    <LinearLayout
        android:id="@+id/controls_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/widget_btn_prev"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="8dp"
            android:src="@drawable/ic_widget_prev"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Previous"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/widget_btn_play_pause"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="8dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_widget_play"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Play/Pause"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/widget_btn_next"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="8dp"
            android:src="@drawable/ic_widget_next"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Text content in the middle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/artwork_container"
        android:layout_toStartOf="@id/controls_container"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:gravity="start|center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Melodix Music Player"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No Song Playing"
            android:textColor="#8F8F9F"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

</RelativeLayout>
